# Имя проекта для docker compose (префикс для сетей/volumes/контейнеров)
DOCKERHUB_NAMESPACE=artluz
COMPOSE_PROJECT_NAME=eng-conference
API_IMAGE_TAG=1.0.0

# --- Webhook auth (Tilda -> сервис) ---
TILDA_API_KEY_NAME=Authorization
TILDA_API_KEY_VALUE=supersecret-token

# --- MongoDB ---
MONGO_URI=mongodb://mongo:27017
MONGO_DB=eng_conference
MONGO_COLLECTION=submissions

# --- Uvicorn / app (опционально) ---
HOST=0.0.0.0
PORT=8000

WEB_USERS_COLLECTION=web_users
WEB_REGISTRATIONS_COLLECTION=conference_registrations
WEB_EMAIL_TASKS_COLLECTION=email_tasks
WEB_PASSWORD_RESET_TOKENS_COLLECTION=password_reset_tokens
WEB_SESSIONS_COLLECTION=web_sessions
WEB_SESSION_COOKIE_NAME=conference_session
WEB_SESSION_TTL_HOURS=1080
WEB_PASSWORD_RESET_TTL_MINUTES=30
WEB_ADMIN_EMAILS=graduate.applications@yandex.ru

WEB_CHECKER_API_URL=http://checker-api:8000/validate
WEB_CHECKER_API_TIMEOUT_SEC=30

WEB_NOTIFICATION_EMAIL_SENDER=graduate.applications@yandex.ru
WEB_NOTIFICATION_EMAIL_PASSWORD=
WEB_NOTIFICATION_EMAIL_SMTP_HOST=smtp.yandex.ru
WEB_NOTIFICATION_EMAIL_SMTP_PORT=465
WEB_NOTIFICATION_EMAIL_USE_SSL=true
MAILER_POLL_INTERVAL_SEC=5
MAILER_RETRY_DELAY_SEC=120
MAILER_PROCESSING_TIMEOUT_SEC=300
MAILER_MAX_ATTEMPTS=5

CHECKER_POLL_INTERVAL_SEC=5
CHECKER_PROCESSING_TIMEOUT_SEC=300

# --- Mongo backup service ---
MONGO_BACKUP_HOST_DIR=../mongo-backups
MONGO_BACKUP_INTERVAL_SEC=7200
MONGO_BACKUP_FILE_PREFIX=mongo
MONGO_BACKUP_KEEP_LAST=24

# --- Worker (downloader/processor) ---
POLL_INTERVAL_SEC=2
LOCK_TIMEOUT_SEC=30
MAX_ATTEMPTS=5

# Куда worker складывает скачанные файлы (внутри контейнера)
# В compose это должно быть примонтировано volume'ом
DOWNLOAD_DIR=/data/downloads

# Идентификатор воркера (удобно для логов/локов)
WORKER_ID=downloader-1

YANDEX_API_URL=https://cloud-api.yandex.net/v1/disk/resources/download/
YANDEX_API_TOKEN=supersecret-token
YANDEX_DISK_PATH='Приложения/Tilda Publishing and Disk/English_test/'

LOG_LEVEL=info
