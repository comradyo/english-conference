# Имя проекта для docker compose (префикс для сетей/volumes/контейнеров)
COMPOSE_PROJECT_NAME=eng-conf-form-handler
API_IMAGE_TAG=1.0.0

# --- Webhook auth (Tilda -> сервис) ---
TILDA_API_KEY_NAME=Authorization
TILDA_API_KEY_VALUE=supersecret-token

# --- MongoDB ---
MONGO_URI=mongodb://mongo:27017
MONGO_DB=eng_conference
MONGO_COLLECTION=submissions

# --- Uvicorn / app (опционально) ---
HOST=0.0.0.0
PORT=8000

# --- Worker (downloader/processor) ---
POLL_INTERVAL_SEC=2
LOCK_TIMEOUT_SEC=30
MAX_ATTEMPTS=5

# Куда worker складывает скачанные файлы (внутри контейнера)
# В compose это должно быть примонтировано volume'ом
DOWNLOAD_DIR=/data/downloads

# Идентификатор воркера (удобно для логов/локов)
WORKER_ID=downloader-1

YANDEX_API_URL=https://cloud-api.yandex.net/v1/disk/resources/download/
YANDEX_API_TOKEN=supersecret-token
YANDEX_DISK_PATH='Приложения/Tilda Publishing and Disk/English_test/'

LOG_LEVEL=info